  vishwakarma: {
    url: "https://vishwakarma.pages.dev/health",
    name: "Vishwakarma",
    expectedStatus: "ok"
  },
  chitragupta: {
    url: "https://chitragupta.pages.dev/api/health",
    name: "Chitragupta",
    expectedStatus: "ok"
  },
  karma: {
    url: "https://karma.compute/health",
    name: "Karma",
    expectedStatus: "healthy"
  },
  kanak: {
    url: "https://kanak.pages.dev/health",
    name: "Kanak",
