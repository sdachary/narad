async function formatBrainStatus(stats) {
  const lines = [
    "\u{1F9E0} NARAD BRAIN STATUS",
    "\u2550".repeat(30),
    "",
    `\u{1F4CA} Source: ${stats.source || "supabase"}`,
    `\u{1F4DA} Total Documents: ${stats.totalDocs}`,
    `\u{1F4A1} Insights: ${stats.totalInsights}`,
    `\u{1F504} Last Scan: ${stats.lastFullScan || "Never"}`,
    `\u{1F680} Initialized: ${stats.initialized || "No"}`,
    ""
  ];
  if (stats.byProject?.length > 0) {
    lines.push("\u{1F4C1} PROJECTS:");
    lines.push(...stats.byProject.map((p) => `  \u2022 ${p.project}: ${p.docCount} docs`));
  }
  return lines.join("\n");
}
