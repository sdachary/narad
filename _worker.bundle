    (kw) => ["bug", "fix", "important", "remember", "note", "context", "project", "architecture"].includes(kw)
  );
  if (isImportant || metadata.important) {
    await addInsight(env, {
      title: message.slice(0, 100),
      content: `Q: ${message}
A: ${response}`,
