      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        chat_id: chatId,
        action
        // 'typing', 'upload_photo', etc.
      })
    });
  } catch (err) {
    console.error("[Hermes] sendTelegramAction error:", err);
  }
}
