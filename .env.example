# ══════════════════════════════════════════════════════════════════════
# ══════════════════════════════════════════════════════════════════════
# VALIDATION: After filling this file:
# 1. Save as .env (this file is gitignored)
# 2. Run: bash scripts/validate-env.sh
# 3. All vars marked REQUIRED must have values
# 4. Optional vars can be left empty (fallback behavior)
# ══════════════════════════════════════════════════════════════════════
# Narad — Environment Variables
# Copy to .env and fill in real values
# .env is gitignored — never commit it
# ══════════════════════════════════════════════════════════════════════

# ── AI Models (all free tier) ─────────────────────────────────────────
GROQ_API_KEY=gsk_...              # console.groq.com — free, fastest
OPENROUTER_API_KEY=sk-or-...      # openrouter.ai — free tier fallback

# ── Memory ────────────────────────────────────────────────────────────
QDRANT_URL=https://xxx.qdrant.io  # cloud.qdrant.io — free 1GB cluster
QDRANT_API_KEY=...                # from Qdrant cloud dashboard

# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...            # @BotFather on Telegram
TELEGRAM_CHAT_ID=...              # your personal chat ID (@userinfobot)

# ── MCP Tools ─────────────────────────────────────────────────────────
BRAVE_API_KEY=...                 # api.search.brave.com — 2000 free/mo
GITHUB_PAT=ghp_...                # github.com/settings/tokens — repo scope

# ── Optional: Nisha platform connection ───────────────────────────────
NISHA_WORKER_URL=https://nisha-cloudprovision.pages.dev
NISHA_WORKER_SECRET=...           # ADMIN_SECRET_TOKEN from cloudprovision worker
