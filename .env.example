# ══════════════════════════════════════════════════════════════════════
# Narad — Environment Variables
# 1. Copy this file: cp .env.example .env
# 2. Fill in every REPLACE_ME value
# 3. NEVER commit .env to git
# ══════════════════════════════════════════════════════════════════════

# ── Required: AI Provider ──────────────────────────────────────────────
# Groq (primary — free, fastest). Get at: console.groq.com → API Keys
GROQ_API_KEY=gsk_REPLACE_ME

# ── Required: Telegram ────────────────────────────────────────────────
# Create bot via @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=REPLACE_ME
# Your personal Telegram user ID. Get from @userinfobot on Telegram.
TELEGRAM_CHAT_ID=REPLACE_ME

# ── Optional: AI Fallback ─────────────────────────────────────────────
# OpenRouter (fallback models — Gemini Flash, DeepSeek R1). Free models available.
# Get at: openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# ── Optional: Web Search Providers ─────────────────────────────────────
# Serper (Google search) — 2,500 queries/month free
# Get at: serper.dev → API Keys
SERPER_API_KEY=REPLACE_ME

# Firecrawl (web scraping & search) — 500 credits/month free
# Get at: firecrawl.dev → API Keys
FIRECRAWL_API_KEY=REPLACE_ME

# ── Optional: MCP Connectors ──────────────────────────────────────────
# GitHub — Create at: github.com/settings/tokens (repo scope)
GITHUB_API_KEY=ghp_REPLACE_ME

# Notion — Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_REPLACE_ME

# Slack — Create at: api.slack.com/apps (Bot Token)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME

# ── Optional: Workers AI ──────────────────────────────────────────────
# Workers AI is automatically available when AI binding is configured
# No API key needed — enabled in wrangler.toml

# ── Optional: Paths ───────────────────────────────────────────────────
# Override if your narad repo is not at ~/narad
# NARAD_DIR=/home/ubuntu/narad
# KNOWLEDGE_DIR=/home/ubuntu/narad/knowledge
# MEMORY_DB=/home/ubuntu/.narad/memory.db

# ── Optional: AGI Worker ──────────────────────────────────────────────
# The Cloudflare Worker that handles Groq inference + memory
# Default: https://nisha-agi.pages.dev
# AGI_WORKER_URL=https://nisha-agi.pages.dev

# ── Optional: Cron config ─────────────────────────────────────────────
# Path to config.example.json to read cron job definitions from
# CRON_CONFIG_PATH=/home/ubuntu/narad/config/config.example.json

# ── Optional: Logging ──────────────────────────────────────────────
# debug | info | warn | error  (default: info)
# LOG_LEVEL=info
