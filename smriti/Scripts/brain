#!/usr/bin/env python3
"""
🧠 brain — Your Second Brain command center.

A single entry point for all Second Brain operations.
Designed to feel natural, like thinking.

Usage:
    brain scan         Scan projects and build knowledge base
    brain watch        Start the file watcher (background neural sync)
    brain watch stop   Stop the background watcher
    brain log          Save an AI conversation (interactive)
    brain log "title"  Quick-save with a title
    brain search term  Search across all notes
    brain status       Show brain health and stats
    brain recall term  Find and display a note by keyword
    brain connect      Build cross-project links (neural pathways)
    brain help         Show this help
"""

import os
import sys
import re
import glob
import subprocess
import datetime
from pathlib import Path

# ─── Paths ───────────────────────────────────────────────────────
VAULT = Path("/home/deepak/SecondBrain")
SCRIPTS = VAULT / "Scripts"
PROJECTS = VAULT / "Projects"
AI_LOGS = VAULT / "AI-Logs"
INBOX = VAULT / "Inbox"
KNOWLEDGE = VAULT / "Knowledge"
PID_FILE = SCRIPTS / ".watcher.pid"
PYTHON = sys.executable


# ─── Colors ──────────────────────────────────────────────────────
class C:
    BOLD = "\033[1m"
    DIM = "\033[2m"
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    CYAN = "\033[96m"
    RED = "\033[91m"
    MAGENTA = "\033[95m"
    RESET = "\033[0m"
    BRAIN = "\033[95;1m"  # Bold magenta


def banner():
    print(f"""
{C.BRAIN}    ╭──────────────────────────────╮
    │  🧠  S E C O N D   B R A I N  │
    ╰──────────────────────────────╯{C.RESET}
    """)


# ─── Commands ────────────────────────────────────────────────────

def cmd_scan():
    """Scan projects and build the knowledge base."""
    print(f"{C.CYAN}⚡ Firing neurons — scanning projects...{C.RESET}\n")
    subprocess.run([PYTHON, str(SCRIPTS / "enhance_notes.py")])
    print(f"\n{C.GREEN}🧠 Knowledge base synced.{C.RESET}")


def cmd_watch(args):
    """Start or stop the background file watcher."""
    if args and args[0] == "stop":
        _stop_watcher()
        return

    if args and args[0] == "status":
        _watcher_status()
        return

    # Check if already running
    if _is_watcher_running():
        print(f"{C.YELLOW}👁️  Watcher is already active.{C.RESET}")
        print(f"   Use: brain watch stop")
        return

    # Try starting via systemd if service file exists
    svc_file = Path.home() / ".config/systemd/user/second-brain.service"
    if svc_file.exists():
        print(f"{C.CYAN}👁️  Starting neural sync (via systemd)...{C.RESET}")
        subprocess.run(["systemctl", "--user", "start", "second-brain.service"])
    else:
        print(f"{C.CYAN}👁️  Starting neural sync (daemon mode)...{C.RESET}")
        subprocess.run([PYTHON, str(SCRIPTS / "file_watcher.py"), "--daemon"])
    
    print(f"{C.GREEN}🧠 Neural pathways active. Changes auto-sync to vault.{C.RESET}")


def _stop_watcher():
    # 1. Try systemd first
    try:
        subprocess.run(["systemctl", "--user", "stop", "second-brain.service"], capture_output=True)
    except Exception:
        pass

    # 2. Kill manual PID if exists
    if PID_FILE.exists():
        pid = PID_FILE.read_text().strip()
        try:
            os.kill(int(pid), 15)  # SIGTERM
            print(f"{C.YELLOW}🛑 Watcher stopped (PID: {pid}){C.RESET}")
        except ProcessLookupError:
            print(f"{C.DIM}Watcher was not running.{C.RESET}")
        PID_FILE.unlink(missing_ok=True)
    else:
        print(f"{C.YELLOW}🛑 Watcher service stopped.{C.RESET}")


def _is_watcher_running() -> bool:
    # 1. Check systemd service if it exists
    try:
        res = subprocess.run(
            ["systemctl", "--user", "is-active", "second-brain.service"],
            capture_output=True, text=True
        )
        if res.stdout.strip() == "active":
            return True
    except Exception:
        pass

    # 2. Fallback to manual PID file
    if not PID_FILE.exists():
        return False
    pid = PID_FILE.read_text().strip()
    try:
        os.kill(int(pid), 0)
        return True
    except (ProcessLookupError, ValueError):
        return False


def _watcher_status():
    if _is_watcher_running():
        # Try to get PID from systemd first
        try:
            res = subprocess.run(
                ["systemctl", "--user", "show", "second-brain.service", "--property=MainPID"],
                capture_output=True, text=True
            )
            pid = res.stdout.split("=")[1].strip()
            if pid and pid != "0":
                print(f"{C.GREEN}👁️  Watcher is running (via systemd, PID: {pid}){C.RESET}")
                return
        except Exception:
            pass

        # Fallback to PID file
        if PID_FILE.exists():
            pid = PID_FILE.read_text().strip()
            print(f"{C.GREEN}👁️  Watcher is running (manual, PID: {pid}){C.RESET}")
        else:
            print(f"{C.GREEN}👁️  Watcher is active.{C.RESET}")
    else:
        print(f"{C.DIM}👁️  Watcher is not running{C.RESET}")


def cmd_log(args):
    """Save an AI conversation."""
    cmd = [PYTHON, str(SCRIPTS / "save_ai_log.py")]
    if args:
        # Treat first arg as title if no flag
        if not args[0].startswith("-"):
            cmd.extend(["--title", args[0]])
            args = args[1:]
        cmd.extend(args)
    subprocess.run(cmd)


def cmd_search(args):
    """Search across all notes using grep."""
    if not args:
        print(f"{C.RED}Usage: brain search <term>{C.RESET}")
        return

    query = " ".join(args)
    print(f"{C.CYAN}🔍 Searching for '{query}' across all neurons...{C.RESET}\n")

    results = []
    for md_file in VAULT.rglob("*.md"):
        # Skip hidden dirs
        if any(part.startswith(".") for part in md_file.relative_to(VAULT).parts):
            continue
        try:
            content = md_file.read_text(encoding="utf-8", errors="replace")
            lines = content.splitlines()
            for i, line in enumerate(lines, 1):
                if re.search(query, line, re.IGNORECASE):
                    results.append((md_file, i, line.strip()))
        except Exception:
            continue

    if not results:
        print(f"{C.DIM}No matches found.{C.RESET}")
        return

    # Group by file
    by_file = {}
    for filepath, lineno, line in results:
        rel = filepath.relative_to(VAULT)
        if rel not in by_file:
            by_file[rel] = []
        by_file[rel].append((lineno, line))

    print(f"{C.GREEN}Found {len(results)} match(es) in {len(by_file)} note(s):{C.RESET}\n")
    for rel, matches in sorted(by_file.items()):
        print(f"  {C.BOLD}📝 {rel}{C.RESET}")
        for lineno, line in matches[:3]:
            # Highlight the query
            highlighted = re.sub(
                f"({re.escape(query)})",
                f"{C.YELLOW}\\1{C.RESET}",
                line,
                flags=re.IGNORECASE,
            )
            print(f"     L{lineno}: {highlighted}")
        if len(matches) > 3:
            print(f"     {C.DIM}... +{len(matches) - 3} more{C.RESET}")
        print()


def cmd_recall(args):
    """Find and display a note by keyword."""
    if not args:
        print(f"{C.RED}Usage: brain recall <keyword>{C.RESET}")
        return

    query = " ".join(args).lower()
    matches = []

    for md_file in VAULT.rglob("*.md"):
        if any(part.startswith(".") for part in md_file.relative_to(VAULT).parts):
            continue
        if query in md_file.stem.lower():
            matches.append(md_file)

    if not matches:
        print(f"{C.DIM}No notes matching '{query}'.{C.RESET}")
        return

    if len(matches) == 1:
        _display_note(matches[0])
        return

    print(f"{C.CYAN}Found {len(matches)} notes:{C.RESET}\n")
    for i, m in enumerate(sorted(matches)[:15], 1):
        rel = m.relative_to(VAULT)
        print(f"  {C.BOLD}{i}.{C.RESET} {rel}")

    print(f"\n{C.DIM}Use: brain recall <more-specific-term>{C.RESET}")


def _display_note(filepath: Path):
    rel = filepath.relative_to(VAULT)
    print(f"\n{C.BOLD}📝 {rel}{C.RESET}\n")
    content = filepath.read_text(encoding="utf-8", errors="replace")
    # Skip frontmatter
    if content.startswith("---"):
        end = content.find("---", 3)
        if end > 0:
            content = content[end + 3:].strip()
    # Show first 40 lines
    lines = content.splitlines()[:40]
    print("\n".join(lines))
    if len(content.splitlines()) > 40:
        print(f"\n{C.DIM}... ({len(content.splitlines()) - 40} more lines){C.RESET}")


def cmd_connect():
    """Build cross-project neural pathways (shared term linking)."""
    print(f"{C.CYAN}🔗 Building cross-project neural pathways...{C.RESET}\n")

    # Collect all project indexes
    indexes = {}
    for idx_file in PROJECTS.rglob("*.md"):
        try:
            content = idx_file.read_text(encoding="utf-8", errors="replace")
            if "type: project-index" in content or "type: parent-index" in content:
                project = idx_file.stem
                indexes[project] = idx_file
        except Exception:
            continue

    if not indexes:
        print(f"{C.DIM}No project indexes found.{C.RESET}")
        return

    # Build a knowledge map note
    today = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
    connections = []

    for project, idx_path in sorted(indexes.items()):
        content = idx_path.read_text(encoding="utf-8", errors="replace")
        # Extract tech stack
        tech_match = re.search(r"\*\*Tech Stack\*\*\s*\|\s*(.+)", content)
        tech = tech_match.group(1).strip() if tech_match else "—"
        # Extract file count
        files_match = re.search(r"\*\*Total Files\*\*\s*\|\s*(\d+)", content)
        files = files_match.group(1) if files_match else "?"
        connections.append(f"| [[{project}]] | {files} | {tech} |")

    connections_table = "\n".join(connections)

    # Find shared technologies across projects
    tech_projects = {}
    for project, idx_path in indexes.items():
        content = idx_path.read_text(encoding="utf-8", errors="replace")
        tech_match = re.search(r"\*\*Tech Stack\*\*\s*\|\s*(.+)", content)
        if tech_match:
            techs = re.findall(r"`(\w[\w-]*)`", tech_match.group(1))
            for t in techs:
                if t not in tech_projects:
                    tech_projects[t] = []
                tech_projects[t].append(project)

    # Only show techs shared across 2+ projects
    shared = {t: ps for t, ps in tech_projects.items() if len(ps) >= 2}
    shared_lines = []
    for tech, projs in sorted(shared.items()):
        links = ", ".join(f"[[{p}]]" for p in projs)
        shared_lines.append(f"- **{tech}** → {links}")
    shared_section = "\n".join(shared_lines) if shared_lines else "No shared technologies detected."

    map_note = f"""---
type: knowledge-map
generated: "{today}"
tags: [map, connections, auto-generated]
---

# 🗺️ Knowledge Map

> Auto-generated map of all projects and their connections.

## 📊 All Projects

| Project | Files | Tech Stack |
|---------|-------|------------|
{connections_table}

## 🔗 Shared Technologies (Neural Pathways)

{shared_section}

## 🕸️ Project Relationships

Projects sharing technology form natural clusters — related knowledge
travels along these pathways.

---

*Auto-generated by `brain connect` on {today}*
"""

    map_path = KNOWLEDGE / "Knowledge-Map.md"
    map_path.write_text(map_note, encoding="utf-8")
    print(f"  📝 Created: Knowledge/Knowledge-Map.md")
    print(f"  🔗 Found {len(shared)} shared technologies across projects")
    print(f"\n{C.GREEN}🧠 Neural pathways connected.{C.RESET}")


def cmd_status():
    """Show brain health and stats."""
    banner()

    # Count notes by section
    sections = {
        "Projects": PROJECTS,
        "AI-Logs": AI_LOGS,
        "Inbox": INBOX,
        "Knowledge": KNOWLEDGE,
    }

    total = 0
    for name, path in sections.items():
        count = len(list(path.rglob("*.md"))) if path.exists() else 0
        total += count
        icon = {"Projects": "🗂️", "AI-Logs": "🤖", "Inbox": "📥", "Knowledge": "📚"}.get(name, "📁")
        bar = "█" * min(count // 2, 30)
        print(f"  {icon} {name:15s} {C.CYAN}{count:4d} notes{C.RESET}  {C.DIM}{bar}{C.RESET}")

    print(f"\n  {C.BOLD}Total neurons: {total}{C.RESET}")

    # Watcher status
    print()
    _watcher_status()

    # Changelog
    if (INBOX / "Changelog.md").exists():
        content = (INBOX / "Changelog.md").read_text()
        changes = content.count("**CREATED**") + content.count("**MODIFIED**") + content.count("**DELETED**")
        print(f"  📋 Changelog entries: {changes}")

    # Last scan
    state_file = SCRIPTS / ".watcher_state.json"
    if state_file.exists():
        mtime = datetime.datetime.fromtimestamp(state_file.stat().st_mtime)
        print(f"  🕐 Last sync: {mtime.strftime('%Y-%m-%d %H:%M')}")

    print()


def cmd_help():
    """Show help."""
    banner()
    print(f"""  {C.BOLD}Commands:{C.RESET}

  {C.GREEN}brain scan{C.RESET}            Scan projects → build knowledge base
  {C.GREEN}brain watch{C.RESET}           Start background neural sync (file watcher)
  {C.GREEN}brain watch stop{C.RESET}      Stop the watcher
  {C.GREEN}brain watch status{C.RESET}    Check watcher status
  {C.GREEN}brain log{C.RESET}             Save AI conversation (interactive)
  {C.GREEN}brain log "title"{C.RESET}     Quick-save with title
  {C.GREEN}brain search <term>{C.RESET}   Search across all notes
  {C.GREEN}brain recall <name>{C.RESET}   Find and display a note
  {C.GREEN}brain connect{C.RESET}         Build cross-project knowledge map
  {C.GREEN}brain status{C.RESET}          Show brain health and stats
  {C.GREEN}brain help{C.RESET}            Show this help
    """)


# ─── Router ──────────────────────────────────────────────────────

COMMANDS = {
    "scan": cmd_scan,
    "watch": cmd_watch,
    "log": cmd_log,
    "search": cmd_search,
    "recall": cmd_recall,
    "connect": cmd_connect,
    "status": cmd_status,
    "help": cmd_help,
}


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("help", "--help", "-h"):
        cmd_help()
        return

    cmd_name = args[0]
    cmd_args = args[1:]

    if cmd_name not in COMMANDS:
        print(f"{C.RED}Unknown command: {cmd_name}{C.RESET}")
        cmd_help()
        return

    handler = COMMANDS[cmd_name]

    # Commands that accept args
    if cmd_name in ("watch", "log", "search", "recall"):
        handler(cmd_args)
    else:
        handler()


if __name__ == "__main__":
    main()
