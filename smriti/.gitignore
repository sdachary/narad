# NeuBrain — App-Independent Knowledge Base

# --- Obsidian Specific ---
# Exclude entire .obsidian directory to maintain portability.
# If you want to sync themes/plugins, you can selectively un-ignore them.
.obsidian/
!.obsidian/graph.json

# --- System & Misc ---
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp

# --- Development & Automation ---
# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

# Logs & Watcher State
watcher.log
.watcher_state.json
AI-Logs/

# Wrangler configuration notes (often contain sensitive bindings)
*wrangler-toml.md
*wrangler-json.md

# --- Secrets & Sensitive Data ---
# Potential environment variables
.env
.env.*
!.env.example

# Authentication & Keys
secrets.*
*.key
*.pem
id_rsa
id_ed25519
*.p12
*.pfx

# Configuration Files that might contain local paths or credentials
config.json
auth.json
